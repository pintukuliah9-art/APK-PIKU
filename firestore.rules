rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        getUserData().role == 'super_admin' || 
        (request.auth.token.email == "kampus2stitbu@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function hasRole(role) {
      return isAuthenticated() && (getUserData().role == role || getUserData().role == 'admin' || isAdmin());
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin() || (isOwner(userId) && (
        request.resource.data.role == 'guest' || 
        (request.resource.data.role == 'super_admin' && request.auth.token.email == "kampus2stitbu@gmail.com") ||
        (request.resource.data.role == 'admin' && request.auth.token.email == "admin@timpiku.com") ||
        (request.resource.data.role == 'marketing_admin' && request.auth.token.email == "marketing@timpiku.com") ||
        (request.resource.data.role == 'hr_admin' && request.auth.token.email == "sdm@timpiku.com") ||
        (request.resource.data.role == 'finance_admin' && request.auth.token.email == "keuangan@timpiku.com") ||
        (request.resource.data.role == 'academic_admin' && request.auth.token.email == "akademik@timpiku.com")
      ));
      allow update: if isAdmin() || (isOwner(userId) && (
        request.resource.data.role == resource.data.role ||
        (request.resource.data.role == 'super_admin' && request.auth.token.email == "kampus2stitbu@gmail.com") ||
        (request.resource.data.role == 'admin' && request.auth.token.email == "admin@timpiku.com") ||
        (request.resource.data.role == 'marketing_admin' && request.auth.token.email == "marketing@timpiku.com") ||
        (request.resource.data.role == 'hr_admin' && request.auth.token.email == "sdm@timpiku.com") ||
        (request.resource.data.role == 'finance_admin' && request.auth.token.email == "keuangan@timpiku.com") ||
        (request.resource.data.role == 'academic_admin' && request.auth.token.email == "akademik@timpiku.com")
      ));
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }

    // Academic / Student Admin
    match /studentAdministrations/{document=**} {
      allow read, write: if hasRole('academic_admin');
    }
    match /students/{document=**} {
      allow read, write: if hasRole('academic_admin');
    }
    match /suratList/{document=**} {
      allow read, write: if hasRole('academic_admin');
    }
    match /inventarisList/{document=**} {
      allow read, write: if hasRole('academic_admin');
    }
    match /adminReports/{document=**} {
      allow read, write: if hasRole('academic_admin');
    }

    // Finance
    match /transactions/{document=**} {
      allow read, write: if hasRole('finance_admin');
    }
    match /dailyAllocations/{document=**} {
      allow read, write: if hasRole('finance_admin');
    }
    match /kasLedger/{document=**} {
      allow read, write: if hasRole('finance_admin');
    }
    match /studentPayments/{document=**} {
      allow read, write: if hasRole('finance_admin');
    }
    match /interKasLoans/{document=**} {
      allow read, write: if hasRole('finance_admin');
    }

    // HR
    match /employees/{document=**} {
      allow read, write: if hasRole('hr_admin');
    }
    match /attendances/{document=**} {
      allow read, write: if hasRole('hr_admin');
    }
    match /leaveRequests/{document=**} {
      allow read, write: if hasRole('hr_admin');
    }

    // Marketing
    match /marketingReports/{document=**} {
      allow read, write: if hasRole('marketing_admin');
    }

    // Internal Reports (General)
    match /reports/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /internalReports/{document=**} {
      allow read, write: if isAuthenticated();
    }
    
    // Fallback for migration
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
